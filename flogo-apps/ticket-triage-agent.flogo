                    "reject_bad_data",
                    "search_incidents",
                    "create_incident"
                ]
            }
        }
    },
    "contrib": "",
    "metadata": {
        "endpoints": [
            {
                "protocol": "http",
                "port": "8080",
                "spec": {
                    "name": "ticket-triage-agent",
                    "version": "1.0.0"
                },
                "title": "TriageHTTPTrigger",
                "swagger": {
                    "swagger": "2.0",
                    "info": {
                        "title": "ticket-triage-agent",
                        "version": "1.0.0",
                        "description": "Triage REST trigger (POST /triage)"
                    },
                    "paths": {
                        "/triage": {
                            "post": {
                                "summary": "triage-main",
                                "operationId": "post_triage",
                                "parameters": [
                                    {
                                        "name": "Authorization",
                                        "in": "header",
                                        "description": "Request parameter",
                                        "required": false,
                                        "type": "string"
                                    },
                                    {
                                        "name": "body",
                                        "in": "body",
                                        "description": "request body parameter",
                                        "required": true,
                                        "schema": {
                                            "$ref": "#/definitions/schema1"
                                        }
                                    }
                                ],
                                "responses": {
                                    "200": {
                                        "description": "Rest Response",
                                        "schema": {
                                            "$ref": "#/definitions/schema2"
                                        }
                                    }
                                },
                                "description": "Entry flow: log event, run agent with MCP tools, return decision",
                                "consumes": [
                                    "application/json"
                                ]
                            }
                        }
                    },
                    "definitions": {
                        "schema1": {
                            "type": "object",
                            "title": "BW6ErrorEvent",
                            "properties": {
                                "timestamp": {
                                    "type": "string"
                                },
                                "correlationId": {
                                    "type": "string"
                                },
                                "appName": {
                                    "type": "string"
                                },
                                "appNode": {
                                    "type": "string"
                                },
                                "processName": {
                                    "type": "string"
                                },
                                "activityName": {
                                    "type": "string"
                                },
                                "errorCode": {
                                    "type": "string"
                                },
                                "errorMsg": {
                                    "type": "string"
                                },
                                "stackTrace": {
                                    "type": "string"
                                },
                                "severity": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "appName",
                                "errorCode",
                                "timestamp"
                            ]
                        },
                        "schema2": {
                            "type": "object",
                            "title": "TriageDecision",
