{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/activity/agentactivity",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-general/src/app/General/trigger/rest",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/connector/llmprovider",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/connector/mcpserverconfig"
  ],
  "name": "ticket-triage-agent",
  "description": "AI-powered triage for integration error events. The AI agent uses MCP tools (exposed by sn-mcp-wrapper) to search, create, merge, or reject ServiceNow incidents autonomously.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#rest",
      "name": "tibco-wi-rest",
      "description": "Triage REST trigger (POST /triage)",
      "settings": {
        "port": 8080,
        "APISpecUpdate": false,
        "swagger": "",
        "swaggerVersion": "v2",
        "authenticationType": "None",
        "username": "",
        "password": "",
        "apiVersion": "1.0.0",
        "secureConnection": false,
        "serverKey": "",
        "caCertificate": ""
      },
      "id": "TriageHTTPTrigger",
      "handlers": [
        {
          "description": "Entry flow: log event, run agent with MCP tools, return decision",
          "settings": {
            "APISpecPath": "",
            "Method": "POST",
            "reqType": "application/json",
            "Path": "/triage",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:triage-main"
            },
            "input": {
              "body": "=$.body",
              "headers": "=$.headers"
            },
            "output": {
              "code": "=$.code",
              "data": "=$.data"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": {}
          },
          "schemas": {
            "reply": {
              "data": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"TriageDecision\",\"properties\":{\"decision\":{\"type\":\"string\"},\"ticketId\":{\"type\":\"string\"},\"confidence\":{\"type\":\"number\"},\"reason\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"TriageDecision\",\"properties\":{\"decision\":{\"type\":\"string\"},\"ticketId\":{\"type\":\"string\"},\"confidence\":{\"type\":\"number\"},\"reason\":{\"type\":\"string\"}}}"
              },
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              },
              "body": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"BW6ErrorEvent\",\"properties\":{\"timestamp\":{\"type\":\"string\"},\"correlationId\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"appNode\":{\"type\":\"string\"},\"processName\":{\"type\":\"string\"},\"activityName\":{\"type\":\"string\"},\"errorCode\":{\"type\":\"string\"},\"errorMsg\":{\"type\":\"string\"},\"stackTrace\":{\"type\":\"string\"},\"severity\":{\"type\":\"string\"}},\"required\":[\"appName\",\"errorCode\",\"timestamp\"]}",
                "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"BW6ErrorEvent\",\"properties\":{\"timestamp\":{\"type\":\"string\"},\"correlationId\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"appNode\":{\"type\":\"string\"},\"processName\":{\"type\":\"string\"},\"activityName\":{\"type\":\"string\"},\"errorCode\":{\"type\":\"string\"},\"errorMsg\":{\"type\":\"string\"},\"stackTrace\":{\"type\":\"string\"},\"severity\":{\"type\":\"string\"}},\"required\":[\"appName\",\"errorCode\",\"timestamp\"]}"
              }
            }
          },
          "name": "triage-main"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:triage-main",
      "data": {
        "name": "triage-main",
        "description": "Entry flow: log event, run agent with MCP tools, return decision",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "LogEvent",
            "type": "label",
            "label": "StartActivity to LogEvent"
          },
          {
            "id": 2,
            "from": "LogEvent",
            "to": "TriageAgent",
            "type": "label",
            "label": "LogEvent to TriageAgent"
          },
          {
            "id": 3,
            "from": "TriageAgent",
            "to": "AuditLog",
            "type": "label",
            "label": "TriageAgent to AuditLog"
          },
          {
            "id": 4,
            "from": "AuditLog",
            "to": "Return",
            "type": "label",
            "label": "AuditLog to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogEvent",
            "name": "LogEvent",
            "description": "Log incoming event",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('Triage event: ', coerce.toString($flow.body))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "TriageAgent",
            "name": "TriageAgent",
            "description": "Agentic AI triage decision using MCP tools from bw6-sn-mcp-wrapper",
            "activity": {
              "ref": "#agentactivity",
              "settings": {
                "llmProviderConnection": "conn://075225de-9fdd-49f1-93cb-1cfffdd24b6b",
                "model": "=$property[\"LLM_MODEL\"]",
                "reasoning": "",
                "temperature": 0,
                "enableGuardrails": false,
                "rateLimit": 1000,
                "tokenLimit": 16384,
                "redactSensitiveData": true,
                "responseType": "JSON",
                "agentHandoffs": "",
                "mcpServers": [
                  "9ad67e43-f78e-4837-9f01-881d9036bcf0"
                ],
                "conversationStoreType": "None",
                "memoryMaxSize": 10,
                "systemPrompt": "You are a ServiceNow triage agent for TIBCO BusinessWorks 6 (BW6) error events. For each event you MUST execute the algorithm below exactly. Do not improvise.\n\n============================================================\nDECISION ALGORITHM (follow top-to-bottom, no shortcuts)\n============================================================\n\nSTEP 1 \u2014 VALIDATE\n  If event.appName is empty/missing OR event.errorCode is empty/missing OR event.timestamp is empty/missing:\n     -> call reject_bad_data(correlationId=event.correlationId, reason=\"Missing required fields appName and errorCode\", timestamp=event.timestamp, appName=event.appName, appNode=event.appNode, processName=event.processName, activityName=event.activityName, errorCode=event.errorCode, errorMsg=event.errorMsg)\n     -> EMIT FINAL JSON with decision=\"BAD_DATA\", ticketId=null, resolution=null. STOP.\n  Else continue to STEP 2.\n\nSTEP 2 \u2014 SEARCH (MANDATORY before any create/append)\n  Call search_incidents(errorCode=event.errorCode, appName=event.appName, window_min=60).\n  Let matches = <tool_result>.response.result   (array of candidates).\n  Let N = length of matches.\n\nSTEP 3 \u2014 TRIAGE DECISION\n\n  CASE A:  N == 0  (no open incidents)\n     -> DECISION = NEW, confidence = 1.0\n     -> call create_incident(short_description=event.errorCode+\" in \"+event.appName, description=event.errorMsg, u_stack_trace=event.stackTrace, u_error_code=event.errorCode, u_app_name=event.appName, u_app_node=event.appNode, u_process_name=event.processName, u_activity_name=event.activityName, u_correlation_id=event.correlationId, urgency=\"2\", impact=\"2\", u_decision_source=\"agent-new\", u_agent_confidence=1.0, u_triage_reason=\"No open incidents matching errorCode and appName\")\n     -> ticketId = <create_incident_result>.response.result.sys_id\n     -> Continue to STEP 4.\n\n  CASE B:  N >= 1  (existing open incidents found)\n     -> Let c = matches[0]\n     -> Score confidence 0.0-1.0:\n          >= 0.85: same processName AND same activityName AND same downstream URL in errorMsg\n          0.75-0.84: same processName but different downstream URL, OR vice versa\n          < 0.75:  different processName AND different downstream URL, OR intermittent/self-healing pattern, OR severity escalated 2+ levels\n     -> If confidence >= 0.75:\n          -> DECISION = DUPLICATE_OF\n          -> call append_occurrence(sys_id=c.sys_id, occurrence_note=\"Seen again at \"+event.timestamp+\" on \"+event.appNode)\n          -> ticketId = c.sys_id\n          -> Skip STEP 4 (resolution already on parent ticket). Go straight to FINAL OUTPUT.\n     -> If confidence < 0.75:\n          -> DECISION = NEW (low-conf, protect SLA)\n          -> call create_incident(short_description=event.errorCode+\" in \"+event.appName, description=event.errorMsg, u_stack_trace=event.stackTrace, u_error_code=event.errorCode, u_app_name=event.appName, u_app_node=event.appNode, u_process_name=event.processName, u_activity_name=event.activityName, u_correlation_id=event.correlationId, urgency=\"2\", impact=\"1\", u_decision_source=\"agent-low-confidence\", u_agent_confidence=<your_score>, u_triage_reason=\"Low confidence match against \"+c.sys_id+\": different process/downstream \u2014 opening separate ticket to protect SLA\")\n          -> ticketId = <create_incident_result>.response.result.sys_id\n          -> call append_occurrence(sys_id=c.sys_id, occurrence_note=\"Agent flagged possible duplicate (low conf=\"+<your_score>+\"): new ticket \"+ticketId+\" opened.\")\n          -> Continue to STEP 4.\n\nSTEP 4 \u2014 RESOLUTION RECOMMENDATION (MANDATORY for all NEW decisions only)\n  4a. Call search_past_resolutions(errorCode=event.errorCode).\n      Let pastFixes = <tool_result>.response.result  (may be empty []).\n  4b. Compose this resolution JSON object:\n      {\n        \"likely_cause\": \"<1-2 sentences: most probable root cause based on errorCode, errorMsg, stackTrace>\",\n        \"recommended_steps\": [\n          \"<step 1: specific BW6/TIBCO action, command, or config check>\",\n          \"<step 2>\",\n          \"<step 3 \u2014 add up to 5 steps>\"\n        ],\n        \"runbook_ref\": \"<runbook ID from pastFixes if present, else null>\",\n        \"estimated_effort\": \"<realistic estimate e.g. 15 min>\",\n        \"based_on_past_fix\": <true if pastFixes was non-empty and influenced steps, else false>,\n        \"disclaimer\": \"AI-suggested \u2014 verify before applying in production.\"\n      }\n      Rules:\n        - recommended_steps MUST be specific to BW6/TIBCO. No generic advice like 'check the logs'.\n        - If pastFixes is non-empty, reference what fixed it before in at least one step.\n  4c. Call update_incident_resolution(sys_id=ticketId, resolution=JSON.stringify(<resolution object>))\n      This persists the recommendation on the ticket. Wait for the tool to return.\n\n============================================================\nABSOLUTE CONSTRAINTS\n============================================================\n- Exactly ONE create_incident call per event (low-conf path also calls append_occurrence).\n- NEVER emit the final JSON before ALL tool calls have returned.\n- ticketId is the raw sys_id string. JSON null ONLY for BAD_DATA.\n- For NEW decisions, update_incident_resolution MUST be called before emitting final JSON.\n- For DUPLICATE_OF decisions, do NOT call update_incident_resolution.\n\n============================================================\nTOOL SIGNATURES\n============================================================\n- search_incidents(errorCode, appName, window_min) -> {response:{result:[{sys_id,u_error_code,u_app_name,u_app_node,u_process_name,opened_at,active,u_occurrence_count}]}}\n- create_incident(short_description, description, u_stack_trace?, u_error_code, u_app_name, u_app_node?, u_process_name?, u_activity_name?, u_correlation_id?, urgency?, impact?, u_decision_source?, u_agent_confidence?, u_triage_reason?) -> {response:{result:{sys_id,number,...}}}\n- append_occurrence(sys_id, occurrence_note?) -> {response:{result:{sys_id,number,u_occurrence_count,...}}}\n- reject_bad_data(correlationId, reason, timestamp?, appName?, appNode?, processName?, activityName?, errorCode?, errorMsg?) -> {response:{result:{status,count}}}\n- search_past_resolutions(errorCode) -> {response:{result:[{sys_id,number,u_error_code,u_app_name,u_resolution_recommendation,sys_updated_on}]}}\n- update_incident_resolution(sys_id, resolution) -> {response:{result:{sys_id,number,...}}}  resolution MUST be a JSON string (stringify the object before passing)\n- fetch_incident(sys_id) -> {response:{result:<incident>}}  (rarely needed)\n\n============================================================\nFINAL OUTPUT \u2014 STRICT JSON ONLY (no prose, no markdown, no code fences)\n============================================================\n{\"decision\":\"NEW|DUPLICATE_OF|BAD_DATA\",\"ticketId\":\"<sys_id or null>\",\"confidence\":<0.0-1.0>,\"reason\":\"<one sentence>\",\"resolution\":{\"likely_cause\":\"<string>\",\"recommended_steps\":[\"<step1>\",\"<step2>\",\"...\"],\"runbook_ref\":\"<string or null>\",\"estimated_effort\":\"<string>\",\"based_on_past_fix\":<true|false>,\"disclaimer\":\"AI-suggested \u2014 verify before applying in production.\"}}"
              },
              "input": {
                "userPrompt": "=string.concat('Triage this BW6 error event and act via MCP tools. Event: ', coerce.toString($flow.body))",
                "conversationId": "=coerce.toString($flow.body.correlationId)"
              }
            }
          },
          {
            "id": "AuditLog",
            "name": "AuditLog",
            "description": "Log agent outcome for audit",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('AUDIT triage outcome: ', coerce.toString($activity[TriageAgent]))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Return agent decision to caller",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": "=$activity[TriageAgent]"
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkxvZ0V2ZW50Ijp7IngiOjE1MSwieSI6NDN9LCJUcmlhZ2VBZ2VudCI6eyJ4IjozNDcsInkiOjQwfSwiQXVkaXRMb2ciOnsieCI6NTQ3LCJ5Ijo0MH0sIlJldHVybiI6eyJ4Ijo3NDksInkiOjQwfX0=",
        "metadata": {
          "input": [
            {
              "name": "headers",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}}"
              }
            },
            {
              "name": "body",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"timestamp\":{\"type\":\"string\"},\"correlationId\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"appNode\":{\"type\":\"string\"},\"processName\":{\"type\":\"string\"},\"activityName\":{\"type\":\"string\"},\"errorCode\":{\"type\":\"string\"},\"errorMsg\":{\"type\":\"string\"},\"stackTrace\":{\"type\":\"string\"},\"severity\":{\"type\":\"string\"}}"
              }
            },
            {
              "name": "requestURI",
              "type": "string"
            },
            {
              "name": "method",
              "type": "string"
            }
          ],
          "output": [
            {
              "name": "code",
              "type": "integer"
            },
            {
              "name": "data",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"decision\":{\"type\":\"string\"},\"ticketId\":{\"type\":\"string\"},\"confidence\":{\"type\":\"number\"},\"reason\":{\"type\":\"string\"}}"
              }
            }
          ],
          "fe_metadata": {
            "input": "{\"type\":\"object\",\"title\":\"TriageHTTPTrigger\",\"properties\":{\"headers\":{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]},\"body\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"BW6ErrorEvent\",\"properties\":{\"timestamp\":{\"type\":\"string\"},\"correlationId\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"appNode\":{\"type\":\"string\"},\"processName\":{\"type\":\"string\"},\"activityName\":{\"type\":\"string\"},\"errorCode\":{\"type\":\"string\"},\"errorMsg\":{\"type\":\"string\"},\"stackTrace\":{\"type\":\"string\"},\"severity\":{\"type\":\"string\"}},\"required\":[\"appName\",\"errorCode\",\"timestamp\"]},\"requestURI\":{\"type\":\"string\",\"required\":false},\"method\":{\"type\":\"string\",\"required\":false}}}",
            "output": "{\"type\":\"object\",\"title\":\"Inputs\",\"properties\":{\"code\":{\"type\":\"integer\"},\"data\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"TriageDecision\",\"properties\":{\"decision\":{\"type\":\"string\"},\"ticketId\":{\"type\":\"string\"},\"confidence\":{\"type\":\"number\"},\"reason\":{\"type\":\"string\"}}}},\"required\":[]}"
          }
        },
        "explicitReply": true
      }
    }
  ],
