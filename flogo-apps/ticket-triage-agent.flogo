{
    "imports": [
        "github.com/project-flogo/flow",
        "github.com/project-flogo/contrib/activity/noop",
        "github.com/tibco/flogo-general/src/app/General/activity/log",
        "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/activity/agentactivity",
        "github.com/project-flogo/contrib/activity/actreturn",
        "github.com/tibco/flogo-general/src/app/General/trigger/rest",
        "github.com/project-flogo/contrib/function/coerce",
        "github.com/project-flogo/contrib/function/string",
        "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/connector/llmprovider",
        "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/connector/mcpserverconfig"
    ],
    "name": "ticket-triage-agent",
    "description": "AI-powered triage for integration error events. The AI agent uses MCP tools (exposed by sn-mcp-wrapper) to search, create, merge, or reject ServiceNow incidents autonomously.",
    "version": "1.0.0",
    "type": "flogo:app",
    "appModel": "1.1.1",
    "tags": [],
    "triggers": [
        {
            "ref": "#rest",
            "name": "tibco-wi-rest",
            "description": "Triage REST trigger (POST /triage)",
            "settings": {
                "port": 8080,
                "APISpecUpdate": false,
                "swagger": "",
                "swaggerVersion": "v2",
                "authenticationType": "None",
                "username": "",
                "password": "",
                "apiVersion": "1.0.0",
                "secureConnection": false,
                "serverKey": "",
                "caCertificate": ""
            },
            "id": "TriageHTTPTrigger",
            "handlers": [
                {
                    "description": "Entry flow: log event, run agent with MCP tools, return decision",
                    "settings": {
                        "APISpecPath": "",
                        "Method": "POST",
                        "reqType": "application/json",
                        "Path": "/triage",
                        "OutputValidation": false
                    },
                    "action": {
                        "ref": "github.com/project-flogo/flow",
                        "settings": {
                            "flowURI": "res://flow:triage-main"
                        },
                        "input": {
                            "body": "=$.body",
                            "headers": "=$.headers"
                        },
                        "output": {
                            "code": "=$.code",
                            "data": "=$.data"
                        }
                    },
                    "reply": {
                        "code": 200,
                        "configureResponseCodes": false,
                        "message": {}
                    },
                    "schemas": {
                        "reply": {
                            "data": {
                                "type": "json",
                                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"TriageDecision\",\"properties\":{\"decision\":{\"type\":\"string\"},\"ticketId\":{\"type\":\"string\"},\"confidence\":{\"type\":\"number\"},\"reason\":{\"type\":\"string\"}}}",
                                "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"TriageDecision\",\"properties\":{\"decision\":{\"type\":\"string\"},\"ticketId\":{\"type\":\"string\"},\"confidence\":{\"type\":\"number\"},\"reason\":{\"type\":\"string\"}}}"
                            },
                            "responseBody": {
                                "type": "json",
                                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
                            }
                        },
                        "output": {
                            "headers": {
                                "type": "json",
                                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
                            },
                            "body": {
                                "type": "json",
                                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"BW6ErrorEvent\",\"properties\":{\"timestamp\":{\"type\":\"string\"},\"correlationId\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"appNode\":{\"type\":\"string\"},\"processName\":{\"type\":\"string\"},\"activityName\":{\"type\":\"string\"},\"errorCode\":{\"type\":\"string\"},\"errorMsg\":{\"type\":\"string\"},\"stackTrace\":{\"type\":\"string\"},\"severity\":{\"type\":\"string\"}},\"required\":[\"appName\",\"errorCode\",\"timestamp\"]}",
                                "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"BW6ErrorEvent\",\"properties\":{\"timestamp\":{\"type\":\"string\"},\"correlationId\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"appNode\":{\"type\":\"string\"},\"processName\":{\"type\":\"string\"},\"activityName\":{\"type\":\"string\"},\"errorCode\":{\"type\":\"string\"},\"errorMsg\":{\"type\":\"string\"},\"stackTrace\":{\"type\":\"string\"},\"severity\":{\"type\":\"string\"}},\"required\":[\"appName\",\"errorCode\",\"timestamp\"]}"
                            }
                        }
                    },
                    "name": "triage-main"
                }
            ]
        }
    ],
    "resources": [
        {
            "id": "flow:triage-main",
            "data": {
                "name": "triage-main",
                "description": "Entry flow: log event, run agent with MCP tools, return decision",
                "links": [
                    {
                        "id": 1,
                        "from": "StartActivity",
                        "to": "LogEvent",
                        "type": "label",
                        "label": "StartActivity to LogEvent"
                    },
                    {
                        "id": 2,
                        "from": "LogEvent",
                        "to": "TriageAgent",
                        "type": "label",
                        "label": "LogEvent to TriageAgent"
                    },
                    {
                        "id": 3,
                        "from": "TriageAgent",
                        "to": "AuditLog",
                        "type": "label",
                        "label": "TriageAgent to AuditLog"
                    },
                    {
                        "id": 4,
                        "from": "AuditLog",
                        "to": "Return",
                        "type": "label",
                        "label": "AuditLog to Return"
                    }
                ],
                "tasks": [
                    {
                        "id": "StartActivity",
                        "name": "StartActivity",
                        "description": "NoOp Activity",
                        "activity": {
                            "ref": "#noop"
                        }
                    },
                    {
                        "id": "LogEvent",
                        "name": "LogEvent",
                        "description": "Log incoming event",
                        "activity": {
                            "ref": "#log",
                            "input": {
                                "Log Level": "INFO",
                                "flowInfo": false,
                                "message": "=string.concat('Triage event: ', coerce.toString($flow.body))",
                                "logLevel": ""
                            }
                        }
                    },
                    {
                        "id": "TriageAgent",
                        "name": "TriageAgent",
                        "description": "Agentic AI triage decision using MCP tools from bw6-sn-mcp-wrapper",
                        "activity": {
                            "ref": "#agentactivity",
                            "settings": {
                                "llmProviderConnection": "conn://075225de-9fdd-49f1-93cb-1cfffdd24b6b",
                                "model": "=$property[\"LLM_MODEL\"]",
                                "reasoning": "",
                                "temperature": 0,
                                "enableGuardrails": false,
                                "rateLimit": 1000,
                                "tokenLimit": 16384,
                                "redactSensitiveData": true,
                                "responseType": "JSON",
                                "agentHandoffs": "",
                                "mcpServers": [
                                    "9ad67e43-f78e-4837-9f01-881d9036bcf0"
                                ],
                                "conversationStoreType": "None",
                                "memoryMaxSize": 10,
                                "systemPrompt": "You are a ServiceNow triage agent for TIBCO BusinessWorks 6 (BW6) error events. For each event you MUST execute the algorithm below exactly. Do not improvise.\n\n============================================================\nDECISION ALGORITHM (follow top-to-bottom, no shortcuts)\n============================================================\n\nSTEP 1 — VALIDATE\n  If event.appName is empty/missing OR event.errorCode is empty/missing OR event.timestamp is empty/missing:\n     -> call reject_bad_data(correlationId=event.correlationId, reason=\"Missing required fields appName and errorCode\", timestamp=event.timestamp, appName=event.appName, appNode=event.appNode, processName=event.processName, activityName=event.activityName, errorCode=event.errorCode, errorMsg=event.errorMsg)\n     -> then EMIT FINAL JSON with decision=\"BAD_DATA\", ticketId=null. STOP.\n  Else continue to STEP 2.\n\nSTEP 2 — SEARCH (MANDATORY before any create/append)\n  Call search_incidents(errorCode=event.errorCode, appName=event.appName, window_min=60).\n  The tool returns an object; the candidates array is at: response.result  (key is \"response\", then \"result\").\n  Let matches = <tool_result>.response.result   — this is the array of candidates.\n  Let N = length of matches.\n\nSTEP 3 — BRANCH ON N\n\n  CASE A:  N == 0   (matches is [] — the array has ZERO elements)\n     -> DECISION = NEW, confidence = 1.0\n     -> call create_incident(short_description=event.errorCode+\" in \"+event.appName, description=event.errorMsg, u_error_code=event.errorCode, u_app_name=event.appName, u_app_node=event.appNode, u_process_name=event.processName, u_activity_name=event.activityName, u_correlation_id=event.correlationId, urgency=\"2\", impact=\"2\", u_decision_source=\"agent-new\", u_agent_confidence=1.0, u_triage_reason=\"No open incidents matching errorCode and appName\")\n     -> ticketId = <create_incident_tool_result>.response.result.sys_id\n     -> EMIT FINAL JSON. STOP. DO NOT call append_occurrence.\n\n  CASE B:  N >= 1   (matches has ONE OR MORE elements)\n     -> Let c = matches[0]  (the best candidate)\n     -> EVALUATE match quality. Score confidence 0.0–1.0 using these criteria:\n          HIGH confidence (>= 0.85):  same processName AND same activityName AND same downstream URL in errorMsg\n          MEDIUM confidence (0.75–0.84): same processName but different downstream URL, OR same downstream URL but different processName\n          LOW confidence (< 0.75):  different processName AND different downstream URL in errorMsg, OR event errorMsg indicates intermittent/self-healing behaviour, OR severity escalated by 2+ levels vs candidate\n     -> If confidence >= 0.75:\n          -> DECISION = DUPLICATE_OF\n          -> call append_occurrence(sys_id=c.sys_id, occurrence_note=\"Seen again at \"+event.timestamp+\" on \"+event.appNode)\n          -> ticketId = <append_occurrence_tool_result>.response.result.sys_id\n          -> EMIT FINAL JSON. STOP.\n     -> If confidence < 0.75:\n          -> DECISION = NEW  (protect SLA — open separate ticket)\n          -> call create_incident(short_description=event.errorCode+\" in \"+event.appName, description=event.errorMsg, u_error_code=event.errorCode, u_app_name=event.appName, u_app_node=event.appNode, u_process_name=event.processName, u_activity_name=event.activityName, u_correlation_id=event.correlationId, urgency=\"2\", impact=\"1\", u_decision_source=\"agent-low-confidence\", u_agent_confidence=<your_score>, u_triage_reason=\"Low confidence match against \"+c.sys_id+\": different process/downstream — opening separate ticket to protect SLA\")\n          -> ticketId = <create_incident_tool_result>.response.result.sys_id\n          -> also call append_occurrence(sys_id=c.sys_id, occurrence_note=\"Agent flagged possible duplicate (low conf=\"+<your_score>+\"): new ticket \"+ticketId+\" opened. Same \"+event.errorCode+\" pattern but different process/downstream — creating new ticket to protect SLA.\")\n          -> EMIT FINAL JSON. STOP.\n\n============================================================\nABSOLUTE CONSTRAINTS (violation = protocol failure)\n============================================================\n- Exactly ONE create/append decision per event (low-confidence path calls both is the only exception).\n- Never emit the final JSON before the action tool has returned.\n- ticketId is a raw string sys_id (no quotes around the word null, no string \"null\"). ticketId is JSON null only for BAD_DATA.\n\n============================================================\nTOOL SIGNATURES\n============================================================\n- search_incidents(errorCode, appName, window_min) -> { response: { result: [candidates...] } }. Access array as <result>.response.result. Each candidate has: sys_id, u_error_code, u_app_name, u_app_node, u_process_name, opened_at, active, u_occurrence_count.\n- create_incident(...) -> { response: { result: { sys_id, number, ... } } }. Access sys_id as <result>.response.result.sys_id.\n- append_occurrence(sys_id, occurrence_note?) -> { response: { result: { sys_id, number, u_occurrence_count, ... } } }. Access sys_id as <result>.response.result.sys_id.\n- reject_bad_data(correlationId, reason, timestamp?, appName?, appNode?, processName?, activityName?, errorCode?, errorMsg?) -> { response: { result: { status, count } } }.\n- fetch_incident(sys_id) -> { response: { result: <incident> } }.  (rarely needed)\n\n============================================================\nFINAL OUTPUT — STRICT JSON ONLY (no prose, no markdown, no code fences)\n============================================================\n{\"decision\":\"NEW|DUPLICATE_OF|BAD_DATA\",\"ticketId\":\"<sys_id or null>\",\"confidence\":<0.0-1.0>,\"reason\":\"<one short sentence explaining your confidence score>\"}"
                            },
                            "input": {
                                "userPrompt": "=string.concat('Triage this BW6 error event and act via MCP tools. Event: ', coerce.toString($flow.body))",
                                "conversationId": "=coerce.toString($flow.body.correlationId)"
                            }
                        }
                    },
                    {
                        "id": "AuditLog",
                        "name": "AuditLog",
                        "description": "Log agent outcome for audit",
                        "activity": {
                            "ref": "#log",
                            "input": {
                                "Log Level": "INFO",
                                "flowInfo": false,
                                "message": "=string.concat('AUDIT triage outcome: ', coerce.toString($activity[TriageAgent]))",
                                "logLevel": ""
                            }
                        }
                    },
                    {
                        "id": "Return",
                        "name": "Return",
                        "description": "Return agent decision to caller",
                        "activity": {
                            "ref": "#actreturn",
                            "settings": {
                                "mappings": {
                                    "code": 200,
                                    "data": "=$activity[TriageAgent]"
                                }
                            }
                        }
                    }
                ],
                "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkxvZ0V2ZW50Ijp7IngiOjE1MSwieSI6NDN9LCJUcmlhZ2VBZ2VudCI6eyJ4IjozNDcsInkiOjQwfSwiQXVkaXRMb2ciOnsieCI6NTQ3LCJ5Ijo0MH0sIlJldHVybiI6eyJ4Ijo3NDksInkiOjQwfX0=",
                "metadata": {
                    "input": [
                        {
                            "name": "headers",
                            "type": "object",
                            "schema": {
                                "type": "json",
                                "value": "{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}}"
                            }
                        },
                        {
                            "name": "body",
                            "type": "object",
                            "schema": {
                                "type": "json",
                                "value": "{\"timestamp\":{\"type\":\"string\"},\"correlationId\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"appNode\":{\"type\":\"string\"},\"processName\":{\"type\":\"string\"},\"activityName\":{\"type\":\"string\"},\"errorCode\":{\"type\":\"string\"},\"errorMsg\":{\"type\":\"string\"},\"stackTrace\":{\"type\":\"string\"},\"severity\":{\"type\":\"string\"}}"
                            }
                        },
                        {
                            "name": "requestURI",
                            "type": "string"
                        },
                        {
                            "name": "method",
                            "type": "string"
                        }
                    ],
                    "output": [
                        {
                            "name": "code",
                            "type": "integer"
                        },
                        {
                            "name": "data",
                            "type": "object",
                            "schema": {
                                "type": "json",
                                "value": "{\"decision\":{\"type\":\"string\"},\"ticketId\":{\"type\":\"string\"},\"confidence\":{\"type\":\"number\"},\"reason\":{\"type\":\"string\"}}"
                            }
                        }
                    ],
                    "fe_metadata": {
                        "input": "{\"type\":\"object\",\"title\":\"TriageHTTPTrigger\",\"properties\":{\"headers\":{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]},\"body\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"BW6ErrorEvent\",\"properties\":{\"timestamp\":{\"type\":\"string\"},\"correlationId\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"appNode\":{\"type\":\"string\"},\"processName\":{\"type\":\"string\"},\"activityName\":{\"type\":\"string\"},\"errorCode\":{\"type\":\"string\"},\"errorMsg\":{\"type\":\"string\"},\"stackTrace\":{\"type\":\"string\"},\"severity\":{\"type\":\"string\"}},\"required\":[\"appName\",\"errorCode\",\"timestamp\"]},\"requestURI\":{\"type\":\"string\",\"required\":false},\"method\":{\"type\":\"string\",\"required\":false}}}",
                        "output": "{\"type\":\"object\",\"title\":\"Inputs\",\"properties\":{\"code\":{\"type\":\"integer\"},\"data\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"title\":\"TriageDecision\",\"properties\":{\"decision\":{\"type\":\"string\"},\"ticketId\":{\"type\":\"string\"},\"confidence\":{\"type\":\"number\"},\"reason\":{\"type\":\"string\"}}}},\"required\":[]}"
                    }
                },
                "explicitReply": true
            }
        }
    ],
    "properties": [
        {
            "name": "AgenticAI.LLMConn.LLM_Provider",
            "type": "string",
            "value": "OpenAI"
        },
        {
            "name": "AgenticAI.LLMConn.API_Key",
            "type": "string",
            "value": "SECRET:Z/NDrHR6qSpQf3gQgGgbpkvP8iicUqdOqudfJXVV0KEwOxMYx3si/x/2iTlgNSabK1Qi9+kCik29tFX5+wu8OzCflTutJeD6nQ=="
        },
